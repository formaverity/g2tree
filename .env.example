# Pl@ntNet species identification
# Get a free API key at https://my.plantnet.org/
# Copy this file to .env.local and fill in your key.
#
# IMPORTANT: Do NOT use the VITE_ prefix. This key must stay server-side.
# It is read by api/plantnet-identify.js (Vercel serverless function) via
# process.env — it is never sent to the browser.
PLANTNET_API_KEY=your_plantnet_api_key_here
