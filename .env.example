# Pl@ntNet species identification
# Get a free API key at https://my.plantnet.org/
# IMPORTANT: Do NOT use the VITE_ prefix. This key must stay server-side.
# It is read by api/plantnet-identify.js (Vercel serverless function) via
# process.env — it is never sent to the browser.
PLANTNET_API_KEY=your_plantnet_api_key_here

# Supabase — required for auth and saved tree profiles
# Create a project at https://supabase.com, then find these in:
# Project Settings → API → Project URL and anon/public key
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase setup required (run in SQL Editor):
#
#   CREATE TABLE g2tree_trees (
#     id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
#     user_id uuid REFERENCES auth.users NOT NULL,
#     created_at timestamptz DEFAULT now(),
#     updated_at timestamptz DEFAULT now(),
#     name text, species text,
#     estimates jsonb, landmarks jsonb, user_hints jsonb,
#     tree_structure_hints jsonb, scale_real_world_dist numeric,
#     species_ai_result jsonb, structure_detection_result jsonb,
#     procedural_params jsonb, preview_mode text
#   );
#   ALTER TABLE g2tree_trees ENABLE ROW LEVEL SECURITY;
#   CREATE POLICY "own trees" ON g2tree_trees
#     USING (auth.uid() = user_id) WITH CHECK (auth.uid() = user_id);
#
#   CREATE TABLE g2tree_tree_photos (
#     id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
#     tree_id uuid REFERENCES g2tree_trees ON DELETE CASCADE NOT NULL,
#     user_id uuid REFERENCES auth.users NOT NULL,
#     created_at timestamptz DEFAULT now(),
#     storage_path text, is_calibration boolean DEFAULT false, exif jsonb
#   );
#   ALTER TABLE g2tree_tree_photos ENABLE ROW LEVEL SECURITY;
#   CREATE POLICY "own photos" ON g2tree_tree_photos
#     USING (auth.uid() = user_id) WITH CHECK (auth.uid() = user_id);
#
# Storage bucket: create "g2tree-photos" as Private in Dashboard → Storage.
# Add an RLS policy on storage.objects:
#   auth.uid()::text = (storage.foldername(name))[1]
